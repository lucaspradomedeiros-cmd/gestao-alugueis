{
  "version": "1.0.0",
  "description": "Schema para dados de gestão de alguéis",
  "lastUpdated": "2026-04-08T00:00:00Z",

  "definitions": {
    "tenant": {
      "type": "object",
      "required": ["id", "unit", "name", "rent", "start", "vencDia"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "ID único do inquilino"
        },
        "unit": {
          "type": "string",
          "description": "Identificação do imóvel (ex: 'Apto 1')"
        },
        "name": {
          "type": "string",
          "description": "Nome completo do inquilino"
        },
        "tel": {
          "type": "string",
          "description": "Telefone para contato"
        },
        "rent": {
          "type": "number",
          "description": "Valor base do aluguel em R$"
        },
        "start": {
          "type": "string",
          "format": "date",
          "description": "Data de início do contrato"
        },
        "end": {
          "type": "string",
          "format": "date",
          "description": "Data de fim do contrato (se aplicável)"
        },
        "reajuste": {
          "type": "string",
          "format": "date",
          "description": "Data do próximo reajuste"
        },
        "garantia": {
          "type": "string",
          "description": "Tipo de garantia (ex: 'Seguro Fiança')"
        },
        "vencDia": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31,
          "description": "Dia do mês de vencimento"
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/payment_entry"
          },
          "description": "Histórico de pagamentos por mês"
        }
      }
    },

    "payment_entry": {
      "type": "object",
      "required": ["ref", "venc", "aluguel", "valorCobrado", "status"],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$",
          "description": "Referência da data (YYYY-MM)"
        },
        "venc": {
          "type": "string",
          "format": "date",
          "description": "Data de vencimento"
        },
        "aluguel": {
          "type": "number",
          "description": "Valor do aluguel"
        },
        "condo": {
          "type": "number",
          "default": 0,
          "description": "Valor do condomínio"
        },
        "iptu": {
          "type": "number",
          "default": 0,
          "description": "Valor do IPTU"
        },
        "lixo": {
          "type": "number",
          "default": 0,
          "description": "Taxa de lixo"
        },
        "multa": {
          "type": "number",
          "default": 0,
          "description": "Multa por atraso (5% do aluguel)"
        },
        "juros": {
          "type": "number",
          "default": 0,
          "description": "Juros mensais (1% ao mês)"
        },
        "pendingMulta": {
          "type": "number",
          "default": 0,
          "description": "Multa acumulada não paga"
        },
        "pendingJuros": {
          "type": "number",
          "default": 0,
          "description": "Juros acumulados não pagos"
        },
        "extras": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "desc": { "type": "string" },
              "valor": { "type": "number" }
            }
          },
          "description": "Despesas extras"
        },
        "valorCobrado": {
          "type": "number",
          "description": "Valor total cobrado"
        },
        "valorPago": {
          "type": "number",
          "description": "Valor total pago"
        },
        "dataPagamento": {
          "type": "string",
          "format": "date",
          "description": "Data do pagamento"
        },
        "status": {
          "type": "string",
          "enum": ["pago", "pendente", "atraso"],
          "description": "Status do pagamento"
        }
      }
    },

    "condo_entry": {
      "type": "object",
      "required": ["ref", "data"],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$",
          "description": "Referência da data (YYYY-MM)"
        },
        "data": {
          "type": "number",
          "description": "Valor do condomínio"
        }
      }
    }
  },

  "root": {
    "type": "object",
    "required": ["version", "tenants"],
    "properties": {
      "version": {
        "type": "string",
        "description": "Versão do schema (semver)"
      },
      "tenants": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/tenant"
        },
        "description": "Lista de inquilinos"
      },
      "condoHistory": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/condo_entry"
        },
        "description": "Histórico de valores de condomínio"
      },
      "exportedAt": {
        "type": "string",
        "format": "date-time",
        "description": "Data/hora da última exportação"
      }
    }
  }
}
